# Copy to .env.local for `vercel dev` (never commit .env.local)

# LLM: Groq powers Startup Signal Scorer.
GROQ_API_KEY=
# Default on server: llama-3.1-8b-instant (higher daily token cap on free tier than 70B).
# Only set GROQ_MODEL if you want to override, e.g. quality vs quota tradeoff:
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=

# Optional — richer related search
SERPER_API_KEY=

# Optional — VC firm discovery (SerpAPI ~100 free searches/mo)
SERPAPI_API_KEY=

# Optional Gemini model override (default: gemini-2.0-flash-lite)
# GEMINI_MODEL=gemini-2.0-flash
