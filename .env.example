# Copy to .env.local for `vercel dev` (never commit .env.local)

# LLM: set at least one. If both are set, the app prefers Groq (separate free-tier pool).
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=

# Optional — richer related search
SERPER_API_KEY=

# Optional Gemini model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
