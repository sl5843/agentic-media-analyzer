# Copy to .env.local for `vercel dev` (never commit .env.local)

# LLM: set at least one. If both are set, the app prefers Groq (separate free-tier pool).
GROQ_API_KEY=
# Default: llama-3.3-70b-versatile. Free tier: llama-3.3-70b hits a low *daily* token cap on long runs — use llama-3.1-8b-instant for more headroom (see Groq console for current limits).
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=

# Optional — richer related search
SERPER_API_KEY=

# Optional — VC firm discovery (SerpAPI ~100 free searches/mo)
SERPAPI_API_KEY=

# Optional Gemini model override (default: gemini-2.0-flash-lite)
# GEMINI_MODEL=gemini-2.0-flash
